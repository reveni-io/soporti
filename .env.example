# ⚠️  Copy this file to .env and fill in the values. NEVER commit .env

# Google Sign-In client id — baked into the frontend build (optional: Google
# sign-in is OFF by default on fresh installs; enable it in /admin). Create an
# OAuth 2.0 Client ID (Web application) at
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Application database — stores authenticated users (required). Docker
# (npm run docker:up) overrides this to reach the db container.
DATABASE_URL=postgresql://soporti:soporti@localhost:5432/soporti

# Secret used to sign session JWTs (required). Use e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-long-random-string

# Session lifetime (optional, defaults to 24h; zeit/ms format e.g. 12h, 7d).
JWT_EXPIRES_IN=24h

# Server port (optional, defaults to 3001)
PORT=3001

# CORS origins, comma-separated (optional; unset = any origin). Not needed when
# client and API share one origin (docker-compose.prod.yml); REQUIRED to be safe
# when the frontend is served from a different domain than the API.
CORS_ORIGIN=http://localhost:5173

# Production compose only (docker-compose.prod.yml, optional):
# POSTGRES_PASSWORD=change-me   # internal Postgres password (never exposed to the host)
# APP_PORT=8080                 # host port the app is served on

# Trust proxy (optional, defaults to 1). Set false when clients connect directly,
# otherwise the per-IP login rate limit can be evaded via X-Forwarded-For.
# TRUST_PROXY=false

# Agent max steps per message (optional, defaults to 20)
AGENT_MAX_ITERATIONS=20

# Repo pool — local git clone cache (optional)
# REPO_POOL_MAX_SIZE=20
# REPO_POOL_TTL_MS=1800000
# REPO_POOL_CLEANUP_MS=300000

# Sentry is NOT an env var: the auth token and organization slug live in the
# database, managed from /admin → Sentry.

# Slack ticket auto-diagnose (optional). Enabled only when the List
# id is set. Needs bot scopes lists:read, lists:write, files:read; give the bot
# access to the List and add a long-text column named per COLUMN_NAME below.
SLACK_AUTODIAGNOSE_LIST_ID=
# SLACK_AUTODIAGNOSE_COLUMN_NAME=Diagnosis
# SLACK_AUTODIAGNOSE_COLUMN_ID=          # override when name lookup can't resolve it
# SLACK_AUTODIAGNOSE_PROFILE=tech        # tech | support
# SLACK_AUTODIAGNOSE_POLL_MS=60000
# SLACK_AUTODIAGNOSE_MAX_ITEMS=5         # tickets diagnosed per poll
# SLACK_AUTODIAGNOSE_MAX_ATTACHMENT_BYTES=5242880
# SLACK_AUTODIAGNOSE_SKIP_ARCHIVED=true
# SLACK_AUTODIAGNOSE_SKIP_BEFORE=2024-01-01T00:00:00Z   # skip backlog before this (ISO/epoch)

# Google Drive tunables (optional)
# GOOGLE_DRIVE_MAX_BYTES=26214400        # max bytes downloaded before parsing (25 MB)
# GOOGLE_DRIVE_MAX_CHARS=50000           # extracted-text ceiling per turn
# GOOGLE_DRIVE_DOWNLOAD_TIMEOUT_MS=60000
# GOOGLE_DRIVE_PARSE_CONCURRENCY=2

# PR review tunables (optional)
# REVIEW_LABEL=soporti-review
# REVIEW_REVIEWER_LOGIN=soporti-bot           # auto-detected from the stored GitHub token
# REVIEW_MAX_CHANGED_LINES=4000          # bigger PRs get partially reviewed
# REVIEW_CONCURRENCY=1
# REVIEW_REASONING_EFFORT=high           # only for reasoning models; none|minimal|low|medium|high|xhigh
