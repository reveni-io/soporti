{
  "name": "soporti-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "React 19 + Vite frontend for Soporti.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reveni-io/soporti.git",
    "directory": "client"
  },
  "license": "Apache-2.0",
  "author": "Reveni",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:landing": "vite build --config vite.landing.config.js",
    "preview": "vite preview",
    "preview:landing": "vite preview --outDir dist-landing",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "react": "^19.2.8",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.4",
    "vitest": "^4.0.18"
  }
